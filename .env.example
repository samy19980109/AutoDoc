# Database
AUTODOC_DATABASE_URL=postgresql://autodoc:autodoc@localhost:5433/autodoc

# Redis
AUTODOC_REDIS_URL=redis://localhost:6379/0

# GitHub
AUTODOC_GITHUB_WEBHOOK_SECRET=your-webhook-secret
AUTODOC_GITHUB_TOKEN=ghp_your-token

# AI Provider (anthropic or openai)
AUTODOC_AI_PROVIDER=anthropic
AUTODOC_ANTHROPIC_API_KEY=sk-ant-your-key
AUTODOC_OPENAI_API_KEY=sk-your-key
AUTODOC_AI_MODEL=claude-sonnet-4-20250514

# Notion
AUTODOC_NOTION_API_KEY=ntn_your-notion-integration-secret
AUTODOC_NOTION_PAGE_ID=your-notion-page-id

# Doc Sync Service
AUTODOC_DOC_SYNC_URL=http://localhost:8002

# Atlassian
AUTODOC_CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
AUTODOC_CONFLUENCE_USERNAME=your-email@company.com
AUTODOC_CONFLUENCE_API_TOKEN=your-confluence-token
AUTODOC_JIRA_URL=https://your-domain.atlassian.net
AUTODOC_JIRA_USERNAME=your-email@company.com
AUTODOC_JIRA_API_TOKEN=your-jira-token

# API Gateway
AUTODOC_API_SECRET_KEY=change-me-in-production
AUTODOC_API_KEYS=key1,key2

# Celery
AUTODOC_CELERY_BROKER_URL=redis://localhost:6379/0
AUTODOC_CELERY_RESULT_BACKEND=redis://localhost:6379/1
